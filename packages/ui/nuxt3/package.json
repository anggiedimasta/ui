{
  "name": "@anggiedimasta/ui-nuxt3",
  "version": "0.0.14",
  "description": "@anggiedimasta ui for Nuxt 3",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    }
  },
  "main": "./dist/module.cjs",
  "types": "./dist/types.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "pnpm build:css && nuxt-module-build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build --stub && nuxi prepare playground",
    "release": "pnpm run lint && pnpm run build && pnpm publish",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./dist/index.css --minify",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "lint": "eslint . --ext .js,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix"
  },
  "devDependencies": {
    "@anggiedimasta/config": "workspace:*",
    "@nuxt/kit": "^3.0.0",
    "@nuxt/module-builder": "^0.2.1",
    "@nuxt/schema": "^3.17.4",
    "@nuxtjs/tailwindcss": "7.0.0-beta.0",
    "@storybook/addon-a11y": "9.0.4",
    "@storybook/addon-docs": "9.0.4",
    "@storybook/addon-themes": "^9.0.4",
    "@storybook/addon-vitest": "9.0.4",
    "@storybook/builder-vite": "^9.0.4",
    "@storybook/manager-api": "^9.0.0-alpha.1",
    "@storybook/preview-api": "^9.0.0-alpha.1",
    "@storybook/test": "9.0.0-alpha.2",
    "@storybook/vue3": "^9.0.4",
    "@storybook/vue3-vite": "9.0.4",
    "@tailwindcss/cli": "^4.1.5",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/vue": "^8.1.0",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/browser": "^3.2.0",
    "@vitest/coverage-v8": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "jsdom": "^26.1.0",
    "nuxt": "^3.17.5",
    "playwright": "^1.52.0",
    "storybook": "9.0.4",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.0.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.0",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1"
  }
}
